# ============================================================================
# CONTINUUM BACKEND — ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to `.env` and fill in real values. Anything left blank that
# is not marked "optional" will prevent the application from starting.
# ============================================================================

# ── Server & URLs ───────────────────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── MongoDB (Atlas or self-hosted) ──────────────────────────────────────────
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/continuum

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate a 256-bit secret, e.g. `openssl rand -base64 32`.
JWT_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
JWT_EXPIRATION=900000

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email

# ── Lemon Squeezy ─────────────────────────────────────────────────────────
# Only one paid plan (VISION) is sold; FREE is the default fallback tier.
LEMONSQUEEZY_API_KEY=ls_live_...
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_...
LEMONSQUEEZY_STORE_ID=store_...
LEMONSQUEEZY_VARIANT_ID_VISION=var_...

# ── Backblaze B2 / S3-compatible storage (Vault) ────────────────────────────
VAULT_B2_ENDPOINT=s3.us-east-005.backblazeb2.com
VAULT_B2_BUCKET=continuum-vaults
VAULT_B2_ACCESS_KEY=your_access_key
VAULT_B2_SECRET_KEY=your_secret_key
VAULT_B2_REGION=us-east-005

# ── Plan limit overrides (optional — defaults in application.properties) ────
# PLAN_FREE_MAX_ENTITIES=20
# PLAN_FREE_MAX_NOTES=50
# PLAN_FREE_MAX_VAULT_SIZE_MB=100
# PLAN_VISION_MAX_VAULT_SIZE_MB=4096
