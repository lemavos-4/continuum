# ──────────────────────────────────────────────────────────────────────────────
# Continuum Frontend — environment variables
# Copy this file to `.env` and adjust for your environment.
# Anything prefixed with VITE_ is exposed to the browser bundle.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the Spring Boot backend (no trailing slash).
# Production:
VITE_API_BASE_URL=https://backend-continuum.onrender.com
# Local dev example:
# VITE_API_BASE_URL=http://localhost:8080

# Vite dev-server port. Do NOT use 8080 — that's the backend.
VITE_DEV_PORT=5173

# Dev mode toggle — set to "true" to expose the email/password login form
# alongside Google sign-in. Leave "false" (or unset) in production.
VITE_DEV_MODE=false

