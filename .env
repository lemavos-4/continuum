## ── Continuum Frontend ──────────────────────────
## Copie para .env e ajuste conforme seu ambiente.

# URL base do backend Spring Boot
VITE_API_BASE_URL=https://continuum-backend.onrender.com


# Porta do dev-server Vite (NÃO usar 8080 — já é do backend)
VITE_DEV_PORT=5173

# Dev mode toggle — "true" expõe o formulário de email/senha no /login.
# Mantenha "false" em produção (somente login via Google).
VITE_DEV_MODE=true


